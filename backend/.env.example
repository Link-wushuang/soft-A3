# LLM Provider: "mock" (无需 API key) 或 "spark" (科大讯飞 Spark，比赛演示)
LLM_PROVIDER=mock

# 科大讯飞 Spark API (REST) — 从讯飞开放平台控制台获取
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_MODEL=4.0Ultra
SPARK_API_URL=https://spark-api-open.xf-yun.com/v1/chat/completions

# 数据库 (默认 SQLite，无需额外安装)
DATABASE_URL=sqlite:///./edupath.db

# JWT
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
