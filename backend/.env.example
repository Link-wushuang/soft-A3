# LLM Provider: "mock" (no API key), "deepseek" (temporary development), or "spark" (final competition backend)
LLM_PROVIDER=mock

# DeepSeek API (temporary development provider)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# Xunfei Spark API (final competition provider)
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_MODEL=generalv3.5
SPARK_API_URL=wss://spark-api.xf-yun.com/v3.5/chat

# Database (MySQL required; create DB first: CREATE DATABASE edupath CHARACTER SET utf8mb4;)
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/edupath?charset=utf8mb4

# JWT
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

